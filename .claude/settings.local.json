{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(brew search:*)",
      "WebFetch(domain:www.cmux.dev)",
      "WebFetch(domain:ghostty.org)",
      "Bash(/Applications/cmux.app/Contents/MacOS/cmux +list-themes)",
      "Bash(mkdir:*)",
      "Bash(ghostty:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(swift run:*)",
      "Bash(npm run dist:*)",
      "Bash(osascript -e:*)"
    ],
    "deny": [
      "Bash(tf:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "language": "Japanese",
  "alwaysThinkingEnabled": true
}
