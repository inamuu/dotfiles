{
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"👀 確認が必要です！操作を承認してください\" with title \"🤖 Claude Code\" subtitle \"⏳ 入力待ち\" sound name \"Blow\"'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"🔐 権限の許可が必要です！確認をお願いします\" with title \"🤖 Claude Code\" subtitle \"⚠️ Permission Request\" sound name \"Blow\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"✅ タスクが完了しました！結果を確認してください\" with title \"🤖 Claude Code\" subtitle \"🎉 Complete!\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | { read -r cmd; if printf '%s' \"$cmd\" | grep -qE '^aws\\s'; then if printf '%s' \"$cmd\" | grep -qEi '\\b(update|delete|remove|create|put|modify|terminate|stop|start|reboot|run-task|run-instances|invoke|enable|disable|attach|detach|register|deregister|associate|disassociate|revoke|restore|import|export|copy|move|sync|send)\\b'; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"hooksにより: AWS書き込み系コマンドはブロックされています\"}}'; fi; fi; }"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r file_path; if [ -n \"$file_path\" ] && printf '%s' \"$file_path\" | grep -Eq '\\.tf$'; then dir=$(dirname \"$file_path\"); (cd \"$dir\" && terraform init && terraform fmt && terraform validate); fi; }",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(brew search:*)",
      "WebFetch(domain:www.cmux.dev)",
      "WebFetch(domain:ghostty.org)",
      "Bash(/Applications/cmux.app/Contents/MacOS/cmux +list-themes)",
      "Bash(mkdir:*)",
      "Bash(ghostty:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(swift run:*)",
      "Bash(npm run dist:*)",
      "Bash(osascript -e:*)",
      "Bash(aws:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(dd:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(tf:*)",
      "Bash(tf apply:*)",
      "Bash(terraform apply:*)",
      "Bash(tf destroy:*)",
      "Bash(terraform destroy:*)",
      "Bash(tf state rm:*)",
      "Bash(terraform state rm:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl cordon:*)",
      "Bash(kubectl uncordon:*)",
      "Bash(kubectl taint:*)",
      "Bash(kubectl set:*)",
      "Bash(kubectl annotate:*)",
      "Bash(kubectl label:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chgrp:*)",
      "Bash(setfacl:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(docker stop:*)",
      "Bash(docker kill:*)",
      "Bash(docker rm:*)",
      "Bash(git rm:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",
      "Bash(git reflog expire:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "mcp__supabase__execute_sql"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "aws-mcp"
  ]
}
