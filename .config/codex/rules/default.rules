prefix_rule(pattern=["rm"], decision="forbidden", justification="File deletion is blocked.")
prefix_rule(pattern=["git", "rm"], decision="forbidden", justification="Tracked file deletion is blocked.")

prefix_rule(pattern=["tf", "apply"], decision="forbidden", justification="Infrastructure mutation is blocked.")
prefix_rule(pattern=["terraform", "apply"], decision="forbidden", justification="Infrastructure mutation is blocked.")
prefix_rule(pattern=["tf", "destroy"], decision="forbidden", justification="Infrastructure mutation is blocked.")
prefix_rule(pattern=["terraform", "destroy"], decision="forbidden", justification="Infrastructure mutation is blocked.")
prefix_rule(pattern=["tf", "state", "rm"], decision="forbidden", justification="Terraform state mutation is blocked.")
prefix_rule(pattern=["terraform", "state", "rm"], decision="forbidden", justification="Terraform state mutation is blocked.")

prefix_rule(pattern=["kubectl", ["apply", "delete", "patch", "scale", "rollout", "drain", "cordon", "uncordon", "taint", "set", "annotate", "label"]], decision="forbidden", justification="Kubernetes mutation is blocked.")
prefix_rule(pattern=["aws"], decision="forbidden", justification="AWS CLI execution is blocked to prevent resource updates.")

prefix_rule(pattern=["sudo"], decision="forbidden", justification="Privilege escalation is blocked.")
prefix_rule(pattern=["chmod"], decision="forbidden", justification="Permission changes are blocked.")
prefix_rule(pattern=["chown"], decision="forbidden", justification="Permission changes are blocked.")
prefix_rule(pattern=["chgrp"], decision="forbidden", justification="Permission changes are blocked.")
prefix_rule(pattern=["setfacl"], decision="forbidden", justification="Permission changes are blocked.")

prefix_rule(pattern=["kill"], decision="forbidden", justification="Process termination is blocked.")
prefix_rule(pattern=["killall"], decision="forbidden", justification="Process termination is blocked.")
prefix_rule(pattern=["pkill"], decision="forbidden", justification="Process termination is blocked.")
prefix_rule(pattern=["systemctl"], decision="forbidden", justification="Service control is blocked.")
prefix_rule(pattern=["service"], decision="forbidden", justification="Service control is blocked.")
prefix_rule(pattern=["docker", ["stop", "kill", "rm"]], decision="forbidden", justification="Container stop/removal is blocked.")

prefix_rule(pattern=["git", "reset"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "rebase"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "commit", "--amend"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "push", "-f"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "filter-branch"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "update-ref"], decision="forbidden", justification="History rewrite is blocked.")
prefix_rule(pattern=["git", "reflog", "expire"], decision="forbidden", justification="History rewrite is blocked.")
