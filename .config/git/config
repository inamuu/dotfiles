[alias]
  ad   = add
  br   = branch
  cm   = commit
  co   = checkout
  df   = diff --color=always
  ft   = fetch
  lg   = log --reverse
  lgo  = log --reverse --oneline
  lg-m = log --reverse --oneline master..HEAD
  lg-d = log --reverse --oneline develop..HEAD
  pl   = pull --prune
  ps   = push -u origin
  psf  = push --force-with-lease origin
  rl   = reflog
  ss   = status -s
  st   = status
  sw   = switch
  swc  = switch -c
  wt   = "!f() { repo=$(basename \"$(git rev-parse --show-toplevel)\"); path=\"$HOME/worktrees/$repo/$1\"; if git show-ref --verify --quiet \"refs/heads/$1\"; then git worktree add \"$path\" \"$1\"; else git worktree add -b \"$1\" \"$path\"; fi; }; f"

[core]
  pager        = ""
  editor       = vim -c \"set fenc=utf-8\"
  quotepath    = false
  whitespace   = cr-at-eol
  excludesfile = ~/.gitignore

[credential]
  helper = osxkeychain

[fetch]
  prune = true # 追跡ブランチを自動削除

[user]
  name  = Kazuma Inamura
  email = 8310973+inamuu@users.noreply.github.com

[ghq]
  root = ~/go/src
  root = ~/ghq

[init]
  defaultBranch = main

[pull]
  rebase = merges
  ff     = only # pullを行った際fast-forward でマージできる状況の場合は merge を、そうでなければ fetch のみ行う
  prune  = true # 追跡ブランチを自動削除

[filter "lfs"]
  process = git-lfs filter-process
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
[commit]
  gpgsign = true
[tag]
  gpgsign = true

# PCごとの設定（signingkey, gpg.program など）。config.local は gitignore 済み
[include]
  path = config.local
